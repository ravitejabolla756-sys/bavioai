{
  "name": "bavio-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Bavio AI website and backend services",
  "main": "server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development PORT=3000 FRONTEND_URL=http://localhost:3000 NEXT_PUBLIC_SITE_URL=http://localhost:3000 BAVIO_API_URL=http://localhost:3000 NEXT_PUBLIC_BACKEND_URL=http://localhost:3000 GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback node --watch server.js",
    "dev:backend": "cross-env NODE_ENV=development PORT=3000 FRONTEND_URL=http://localhost:3000 NEXT_PUBLIC_SITE_URL=http://localhost:3000 BAVIO_API_URL=http://localhost:3000 NEXT_PUBLIC_BACKEND_URL=http://localhost:3000 GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback node --watch server.js",
    "dev:full": "npm run dev",
    "build": "next build",
    "start": "cross-env NODE_ENV=production node server.js",
    "start:backend": "cross-env NODE_ENV=production node server.js",
    "db:init": "node database/init.js",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@react-oauth/google": "^0.12.1",
    "@supabase/supabase-js": "^2.78.0",
    "@vercel/analytics": "^1.4.1",
    "axios": "^1.6.5",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "form-data": "^4.0.0",
    "framer-motion": "^11.11.9",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^0.451.0",
    "next": "^14.2.25",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^3.26.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
