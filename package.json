    "@radix-ui/react-tabs": "^1.1.0",
    "@react-oauth/google": "^0.12.1",
    "@supabase/supabase-js": "^2.39.0",
    "@vercel/analytics": "^1.4.1",
    "axios": "^1.6.5",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "form-data": "^4.0.0",
