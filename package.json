{
  "name": "bavio-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Bavio AI website and backend services",
  "scripts": {
    "dev": "cross-env PORT=3000 next dev",
    "dev:backend": "cross-env PORT=5000 FRONTEND_URL=http://localhost:3000 NEXT_PUBLIC_SITE_URL=http://localhost:3000 node --watch server.js",
    "dev:full": "concurrently \"npm:dev:backend\" \"npm:dev\"",
    "build": "next build",
    "start": "next start",
    "start:backend": "node server.js",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json"
  },
